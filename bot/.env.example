# Secrets — copy to .env and fill in (never commit .env)
TELEGRAM_BOT_TOKEN=
OWNER_USER_ID=

# Local Bot API (optional — bypasses file size limits)
# https://core.telegram.org/bots/api#using-a-local-bot-api-server
USE_LOCAL_BOT_API=false
LOCAL_BOT_API_URL=http://127.0.0.1:8081

# Rate limiting (seconds between outbound API calls — min 5 per bot-market guidance)
ACTION_DELAY_SECONDS=5

# Persistence
DATA_DIR=./data
QUEUE_DB=./data/queue.db
SESSIONS_DB=./data/sessions.db
AUTH_DB=./data/auth.db

# Premium emoji pool (comma-separated custom emoji IDs — optional)
PREMIUM_EMOJI_IDS=
PREMIUM_EMOJI_ENABLED=true

# Auto backup to owner (Tuesday UTC)
AUTO_BACKUP_ENABLED=true
AUTO_BACKUP_HOUR_UTC=9

# Web app URL (for sharing)
WEB_APP_URL=https://alexrabbit.github.io/Group-Pay-Split-Bill/
