[Unit]
Description=Group Pay Split Bill Telegram Bot
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/group-pay-split-bill/bot
EnvironmentFile=/opt/group-pay-split-bill/bot/.env
ExecStart=/usr/bin/python3 bot.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
